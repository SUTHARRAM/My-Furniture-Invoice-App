{"ast":null,"code":"import{useEffect,useState}from'react';export function useDebounce(value){let delay=arguments.length>1&&arguments[1]!==undefined?arguments[1]:400;const[debounced,setDebounced]=useState(value);useEffect(()=>{const h=setTimeout(()=>setDebounced(value),delay);return()=>clearTimeout(h);},[value,delay]);return debounced;}","map":{"version":3,"names":["useEffect","useState","useDebounce","value","delay","arguments","length","undefined","debounced","setDebounced","h","setTimeout","clearTimeout"],"sources":["/home/ram/mycode/My-Furniture-Invoice-App/frontend/src/hooks/useDebounce.ts"],"sourcesContent":["import { useEffect, useState } from 'react';\n\nexport function useDebounce<T>(value: T, delay = 400): T {\n  const [debounced, setDebounced] = useState(value);\n  useEffect(() => {\n    const h = setTimeout(() => setDebounced(value), delay);\n    return () => clearTimeout(h);\n  }, [value, delay]);\n  return debounced;\n}\n"],"mappings":"AAAA,OAASA,SAAS,CAAEC,QAAQ,KAAQ,OAAO,CAE3C,MAAO,SAAS,CAAAC,WAAWA,CAAIC,KAAQ,CAAkB,IAAhB,CAAAC,KAAK,CAAAC,SAAA,CAAAC,MAAA,IAAAD,SAAA,MAAAE,SAAA,CAAAF,SAAA,IAAG,GAAG,CAClD,KAAM,CAACG,SAAS,CAAEC,YAAY,CAAC,CAAGR,QAAQ,CAACE,KAAK,CAAC,CACjDH,SAAS,CAAC,IAAM,CACd,KAAM,CAAAU,CAAC,CAAGC,UAAU,CAAC,IAAMF,YAAY,CAACN,KAAK,CAAC,CAAEC,KAAK,CAAC,CACtD,MAAO,IAAMQ,YAAY,CAACF,CAAC,CAAC,CAC9B,CAAC,CAAE,CAACP,KAAK,CAAEC,KAAK,CAAC,CAAC,CAClB,MAAO,CAAAI,SAAS,CAClB","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}