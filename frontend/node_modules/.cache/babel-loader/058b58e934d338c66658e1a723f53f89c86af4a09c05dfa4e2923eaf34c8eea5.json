{"ast":null,"code":"import{useAuthStore}from'../store/authStore';import{authApi}from'../api/authApi';import{useNavigate}from'react-router-dom';export function useAuth(){const{user,isAuthenticated,setAuth,clearAuth}=useAuthStore();const navigate=useNavigate();const login=async(email,password)=>{const res=await authApi.login({email,password});const{access_token,user:u}=res.data.data;setAuth(u,access_token);navigate('/dashboard');};const logout=async()=>{try{await authApi.logout();}catch{}clearAuth();navigate('/login');};return{user,isAuthenticated,login,logout};}","map":{"version":3,"names":["useAuthStore","authApi","useNavigate","useAuth","user","isAuthenticated","setAuth","clearAuth","navigate","login","email","password","res","access_token","u","data","logout"],"sources":["/home/ram/mycode/My-Furniture-Invoice-App/frontend/src/hooks/useAuth.ts"],"sourcesContent":["import { useAuthStore } from '../store/authStore';\nimport { authApi } from '../api/authApi';\nimport { useNavigate } from 'react-router-dom';\n\nexport function useAuth() {\n  const { user, isAuthenticated, setAuth, clearAuth } = useAuthStore();\n  const navigate = useNavigate();\n\n  const login = async (email: string, password: string) => {\n    const res = await authApi.login({ email, password });\n    const { access_token, user: u } = res.data.data;\n    setAuth(u, access_token);\n    navigate('/dashboard');\n  };\n\n  const logout = async () => {\n    try { await authApi.logout(); } catch {}\n    clearAuth();\n    navigate('/login');\n  };\n\n  return { user, isAuthenticated, login, logout };\n}\n"],"mappings":"AAAA,OAASA,YAAY,KAAQ,oBAAoB,CACjD,OAASC,OAAO,KAAQ,gBAAgB,CACxC,OAASC,WAAW,KAAQ,kBAAkB,CAE9C,MAAO,SAAS,CAAAC,OAAOA,CAAA,CAAG,CACxB,KAAM,CAAEC,IAAI,CAAEC,eAAe,CAAEC,OAAO,CAAEC,SAAU,CAAC,CAAGP,YAAY,CAAC,CAAC,CACpE,KAAM,CAAAQ,QAAQ,CAAGN,WAAW,CAAC,CAAC,CAE9B,KAAM,CAAAO,KAAK,CAAG,KAAAA,CAAOC,KAAa,CAAEC,QAAgB,GAAK,CACvD,KAAM,CAAAC,GAAG,CAAG,KAAM,CAAAX,OAAO,CAACQ,KAAK,CAAC,CAAEC,KAAK,CAAEC,QAAS,CAAC,